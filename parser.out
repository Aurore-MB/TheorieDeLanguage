Grammar

Rule 0     S' -> start
Rule 1     start -> bloc
Rule 2     bloc -> bloc statement SEMICOLON
Rule 3     bloc -> statement SEMICOLON
Rule 4     statement -> NAME EGAL expression
Rule 5     statement -> PRINT LPAREN expression RPAREN
Rule 6     expression -> expression PLUS expression
Rule 7     expression -> expression MINUS expression
Rule 8     expression -> expression TIMES expression
Rule 9     expression -> expression DIVIDE expression
Rule 10    expression -> LPAREN expression RPAREN
Rule 11    expression -> NUMBER
Rule 12    expression -> NAME
Rule 13    statement -> LACC bloc RACC
Rule 14    statement -> IF LPAREN expression RPAREN statement
Rule 15    statement -> IF LPAREN expression RPAREN statement ELSE statement
Rule 16    statement -> WHILE LPAREN expression RPAREN statement
Rule 17    statement -> FOR LPAREN statement SEMICOLON expression SEMICOLON statement RPAREN statement
Rule 18    expression -> expression EGALEGAL expression
Rule 19    expression -> expression INF expression
Rule 20    expression -> expression SUP expression
Rule 21    expression -> expression INFEG expression
Rule 22    expression -> expression SUPFEG expression
Rule 23    statement -> NAME PLUSPLUS
Rule 24    statement -> NAME MINUSMINUS
Rule 25    statement -> NAME PLUSEGAL expression
Rule 26    statement -> NAME MINUSEGAL expression
Rule 27    statement -> NAME TIMESEGAL expression
Rule 28    statement -> NAME DIVIDEEGAL expression

