Rule 6     bloc -> definition
Rule 7     bloc -> if_block
Rule 8     bloc -> empty
Rule 9     if_block -> IF LPAREN expression RPAREN LACC bloc RACC
Rule 10    if_block -> IF LPAREN expression RPAREN LACC bloc RACC ELSE LACC bloc RACC
Rule 11    definition -> DEF NAME LPAREN params RPAREN LACC bloc RACC
Rule 12    params -> params COMMA NAME
Rule 13    params -> NAME
Rule 14    params -> empty
Rule 15    expression -> NAME LPAREN args RPAREN
Rule 16    args -> args COMMA expression
Rule 17    args -> expression
Rule 18    args -> empty
Rule 19    statement -> NAME LPAREN args RPAREN
Rule 20    statement -> RETURN expression
Rule 21    statement -> NAME EGAL expression
